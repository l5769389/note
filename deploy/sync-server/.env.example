# Initial administrator. The first startup stores this user in SQLite.
# Change the password after login if you expose a management UI later.
NOTEDOCK_ADMIN_USERNAME=admin
NOTEDOCK_ADMIN_PASSWORD=replace-with-a-long-random-password

# Optional legacy token for older clients. New clients should log in and create
# per-device sync tokens instead of sharing this value.
# Example: openssl rand -hex 32
NOTEDOCK_SYNC_TOKEN=

# Bind to 127.0.0.1 when using Nginx/Caddy on the same server.
# Use 0.0.0.0 only for a private network, VPN, or temporary testing.
NOTEDOCK_SYNC_BIND=127.0.0.1

# Persist sync files and SQLite outside the container.
NOTEDOCK_SYNC_DATA_DIR=/srv/notedock-sync/data
