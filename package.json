{
  "name": "typora-like-editor",
  "version": "0.1.0",
  "description": "A clean Typora-style Markdown writing app.",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "ensure:electron": "node scripts/ensure-electron.cjs",
    "predev": "npm run ensure:electron",
    "dev": "electron-vite dev",
    "build": "tsc -b && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis",
    "icons": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "test": "vitest run",
    "prepreview": "npm run ensure:electron",
    "preview": "electron-vite preview"
  },
  "build": {
    "appId": "com.local.markdownstudio",
    "productName": "Markdown Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Markdown Studio",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeader": "resources/installer-header.bmp",
      "installerSidebar": "resources/installer-sidebar.bmp",
      "uninstallerSidebar": "resources/uninstaller-sidebar.bmp"
    }
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/plugin-prism": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-deflist": "^1.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.5.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "@excalidraw/excalidraw": {
      "nanoid": "^3.3.12"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "^5.0.9"
    },
    "lodash-es": "^4.18.1"
  }
}
