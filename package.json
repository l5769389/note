{
  "name": "typora-like-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "electron": "wait-on http://127.0.0.1:5173 && electron .",
    "desktop:dev": "concurrently -k -n vite,electron -c blue,green \"npm run dev -- --port 5173\" \"npm run electron\"",
    "desktop:preview": "npm run build && cross-env ELECTRON_RENDERER_MODE=production electron .",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "typescript": "^5.5.3",
    "vite": "^6.4.2",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "@excalidraw/excalidraw": {
      "nanoid": "^3.3.12"
    },
    "@excalidraw/mermaid-to-excalidraw": {
      "nanoid": "^5.0.9"
    },
    "lodash-es": "^4.18.1"
  }
}
