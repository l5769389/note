{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": false,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "out",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["server/**/*", "src/shared/**/*"]
}
